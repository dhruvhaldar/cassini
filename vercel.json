{
  "buildCommand": null,
  "functions": {
    "api/index.py": {
      "runtime": "@vercel/python",
      "includeFiles": "public/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.py"
    },
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
